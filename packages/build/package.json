{
  "name": "@swifttui/build",
  "version": "0.1.15",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SwiftTUI/swift-tui-web.git",
    "directory": "packages/build"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "swifttui-web": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "build:manifest": "bun run cli.ts build:manifest",
    "build:wasm": "bun run cli.ts build:wasm",
    "test": "bun test",
    "prepublishOnly": "tsdown"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@swifttui/web": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "1.3.13"
  }
}
