{
  "name": "@swifttui/web",
  "version": "0.0.12",
  "license": "MIT",
  "module": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./manifest": "./manifest.ts",
    "./style.css": "./style.css",
    "./testing": "./testing.ts",
    "./wasi": "./wasi.ts",
    "./wasi-worker": "./wasi-worker.ts",
    "./websocket": "./websocket.ts"
  },
  "type": "module",
  "scripts": {
    "build:manifest": "bun run --cwd ../build build:manifest -- --dist ../web/dist",
    "build:wasm": "bun run --cwd ../build build:wasm -- --dist ../web/dist",
    "build:web": "bun run cli.ts build:web",
    "build": "bun run cli.ts build",
    "dev": "bun run cli.ts dev",
    "test": "bun test"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.13"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
